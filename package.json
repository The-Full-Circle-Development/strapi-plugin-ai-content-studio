{
  "name": "strapi-plugin-ai-content-studio",
  "version": "1.2.0",
  "description": "Multi-provider AI assistant embedded in the Strapi v5 admin panel (chat + tool calling over the Document Service, encrypted provider keys, RBAC).",
  "license": "MIT",
  "keywords": [
    "strapi",
    "strapi-plugin",
    "plugin",
    "ai",
    "ai-sdk",
    "anthropic",
    "openai",
    "google"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/The-Full-Circle-Development/strapi-plugin-ai-content-studio.git"
  },
  "type": "commonjs",
  "exports": {
    "./package.json": "./package.json",
    "./strapi-admin": {
      "source": "./admin/src/index.ts",
      "import": "./dist/admin/index.mjs",
      "require": "./dist/admin/index.js",
      "default": "./dist/admin/index.js"
    },
    "./strapi-server": {
      "source": "./server/src/index.ts",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "strapi-plugin build",
    "watch": "strapi-plugin watch",
    "watch:link": "strapi-plugin watch:link",
    "verify": "strapi-plugin verify",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "^3",
    "@ai-sdk/google": "^3",
    "@ai-sdk/openai": "^3",
    "@ai-sdk/react": "^3",
    "@strapi/design-system": "^2",
    "@strapi/icons": "^2",
    "@strapi/sdk-plugin": "^6",
    "@strapi/strapi": "^5",
    "@types/node": "^20.19.43",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "ai": "^6",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-intl": "^6.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "styled-components": "^6.0.0",
    "typescript": "^5",
    "zod": "^4"
  },
  "peerDependencies": {
    "@strapi/design-system": "^2.0.0",
    "@strapi/icons": "^2.0.0",
    "@strapi/strapi": "^5.0.0",
    "react": "^17.0.0 || ^18.0.0",
    "react-dom": "^17.0.0 || ^18.0.0",
    "react-intl": "^6.0.0",
    "react-router-dom": "^6.0.0",
    "styled-components": "^6.0.0"
  },
  "strapi": {
    "name": "ai-content-studio",
    "displayName": "AI Content Studio",
    "description": "Multi-provider AI assistant for managing content from the admin panel.",
    "kind": "plugin"
  },
  "engines": {
    "node": ">=20.0.0 <=24.x.x"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
